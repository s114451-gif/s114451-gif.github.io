            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
        }
        .container {
            background: rgba(255, 255, 255, 0.05);
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 500px;
            width: 100%;
            text-align: center;
        }
        h1 {
            color: #ffd700;
            margin-bottom: 25px;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }
        .question-group {
            margin-bottom: 20px;
            text-align: left;
            background: rgba(255, 255, 255, 0.02);
            padding: 15px;
            border-radius: 8px;
        }
        .question-title {
            font-size: 1.1rem;
            margin-bottom: 10px;
            color: #e0e0ff;
        }
        label {
            display: block;
            margin: 8px 0;
            cursor: pointer;
            transition: color 0.2s;
        }
        label:hover {
            color: #ffd700;
        }
        input[type="radio"] {
            margin-right: 10px;
            accent-color: #ffd700;
        }
        button {
            background: linear-gradient(45deg, #ff007f, #7f00ff);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1.2rem;
            border-radius: 25px;
            cursor: pointer;
            margin-top: 15px;
            box-shadow: 0 4px 15px rgba(255, 0, 127, 0.4);
            transition: transform 0.2s, box-shadow 0.2s;
            width: 100%;
        }
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 0, 127, 0.6);
        }
        #result-box {
            margin-top: 25px;
            padding: 20px;
            background: rgba(255, 215, 0, 0.1);
            border: 2px dashed #ffd700;
            border-radius: 8px;
            display: none;
            animation: fadeIn 0.5s ease-out;
        }
        #result-text {
            font-size: 1.5rem;
            font-weight: bold;
            color: #ffd700;
            margin: 10px 0;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🔮 午餐命運之輪</h1>
